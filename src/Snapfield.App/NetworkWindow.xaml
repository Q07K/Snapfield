<Window x:Class="Snapfield.App.NetworkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Snapfield.App.ViewModels"
        Title="Snapfield — Network" Height="430" Width="460"
        Background="#1E1E22" Topmost="True" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:NetworkViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <!-- ═══════════ Page 1: role selection ═══════════ -->
        <StackPanel Visibility="{Binding IsChoosePage, Converter={StaticResource BoolToVis}}"
                    VerticalAlignment="Center">
            <TextBlock Foreground="#EEE" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Run Text="이 PC ("/><Run Text="{Binding MachineName, Mode=OneWay}" FontWeight="Bold"/><Run Text=")의 역할을 선택하세요"/>
            </TextBlock>

            <Button Command="{Binding ChooseControllerCommand}" Padding="0" Margin="0,0,0,12"
                    Background="#2E5CB8" BorderBrush="#4A7BE0" Cursor="Hand">
                <StackPanel Margin="16,12">
                    <TextBlock Text="🖱️  제어할 기기 (Controller)" Foreground="White" FontSize="15" FontWeight="Bold"/>
                    <TextBlock Text="이 PC의 마우스로 다른 PC를 조종합니다" Foreground="#CDE" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding ChooseReceiverCommand}" Padding="0"
                    Background="#2E7D4F" BorderBrush="#4AB07A" Cursor="Hand">
                <StackPanel Margin="16,12">
                    <TextBlock Text="🖥️  제어당할 기기 (Receiver)" Foreground="White" FontSize="15" FontWeight="Bold"/>
                    <TextBlock Text="다른 PC의 마우스가 이 PC로 넘어옵니다" Foreground="#CDE" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- ═══════════ Page 2: receiver ═══════════ -->
        <StackPanel Visibility="{Binding IsReceiverPage, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="← 뒤로" Command="{Binding BackCommand}" Padding="8,3"/>
                <TextBlock Text="제어당할 기기" Foreground="#EEE" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <Border Background="#26262C" CornerRadius="8" Padding="14" Margin="0,14,0,0">
                <StackPanel>
                    <TextBlock Text="이 PC의 IP (제어할 기기에서 입력)" Foreground="#9AB" FontSize="11"/>
                    <TextBlock Text="{Binding LocalIps, Mode=OneWay}" Foreground="#FFD75E" FontSize="20"
                               FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="Port" Foreground="#AAB" VerticalAlignment="Center"/>
                <TextBox Text="{Binding Port}" Width="80" Margin="8,0,0,0" VerticalContentAlignment="Center"/>
                <Button Content="Listen — 연결 대기 시작" Command="{Binding ListenCommand}"
                        Padding="14,6" Margin="16,0,0,0" FontWeight="Bold"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Padding="10,6" Margin="8,0,0,0"/>
            </StackPanel>

            <Border Margin="0,14,0,0" CornerRadius="8" Padding="14" Background="{Binding SideBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding Side}" Foreground="White" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Detail}" Foreground="#EEE" HorizontalAlignment="Center" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding Status}" Foreground="#889" TextWrapping="Wrap" Margin="0,12,0,0" FontSize="11"/>
        </StackPanel>

        <!-- ═══════════ Page 3: controller ═══════════ -->
        <StackPanel Visibility="{Binding IsControllerPage, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="← 뒤로" Command="{Binding BackCommand}" Padding="8,3"/>
                <TextBlock Text="제어할 기기" Foreground="#EEE" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <TextBlock Text="제어당할 PC 화면에 표시된 IP를 입력하세요" Foreground="#9AB" Margin="0,14,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding RemoteHost, UpdateSourceTrigger=PropertyChanged}" Width="190"
                         FontSize="15" VerticalContentAlignment="Center"/>
                <TextBlock Text=":" Foreground="#AAB" VerticalAlignment="Center" Margin="6,0"/>
                <TextBox Text="{Binding Port}" Width="70" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Connect — 연결" Command="{Binding ConnectCommand}" Padding="14,6" FontWeight="Bold"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Padding="10,6" Margin="8,0,0,0"/>
            </StackPanel>

            <Border Margin="0,14,0,0" CornerRadius="8" Padding="14" Background="{Binding SideBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding Side}" Foreground="White" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Detail}" Foreground="#EEE" HorizontalAlignment="Center" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="연결되면 커서를 화면 오른쪽 끝으로 밀어 상대 PC로 넘어갑니다."
                       Foreground="#778" FontSize="11" Margin="0,10,0,0"/>
            <TextBlock Text="{Binding Status}" Foreground="#889" TextWrapping="Wrap" Margin="0,6,0,0" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>
