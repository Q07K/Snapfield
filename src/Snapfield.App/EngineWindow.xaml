<Window x:Class="Snapfield.App.EngineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Snapfield.App.ViewModels"
        Title="Snapfield — Input Engine" Height="360" Width="440"
        Background="#1E1E22" Topmost="True" WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <vm:EngineViewModel/>
    </Window.DataContext>
    <StackPanel Margin="16">
        <TextBlock Text="{Binding RunLabel}" Foreground="#EEE" FontSize="16" FontWeight="Bold"/>

        <!-- Live side indicator -->
        <Border Margin="0,12" CornerRadius="8" Padding="16" Background="{Binding SideBrush}">
            <StackPanel>
                <TextBlock Text="{Binding Side}" Foreground="White" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ActiveMonitor}" Foreground="#FFF" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding VirtualPos}" Foreground="#EEE" HorizontalAlignment="Center" FontSize="11"/>
            </StackPanel>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,4">
            <Button Content="Start engine" Command="{Binding StartCommand}" Padding="14,6" Margin="0,0,8,0"/>
            <Button Content="Stop engine" Command="{Binding StopCommand}" Padding="14,6"/>
        </StackPanel>

        <CheckBox Content="Use phantom remote screen (single-machine test)" IsChecked="{Binding UsePhantom}"
                  Foreground="#DDE" Margin="0,12,0,0"/>

        <TextBlock Text="Remote cursor speed" Foreground="#AAB" Margin="0,12,0,2"/>
        <Slider Minimum="0.25" Maximum="3.0" Value="{Binding Sensitivity}" TickFrequency="0.25" IsSnapToTickEnabled="True"/>

        <TextBlock Text="{Binding Hint}" Foreground="#889" TextWrapping="Wrap" Margin="0,12,0,0" FontSize="11"/>
        <TextBlock Foreground="#775" TextWrapping="Wrap" Margin="0,8,0,0" FontSize="11"
                   Text="Stuck on the phantom? Just move the mouse left to return — control releases automatically."/>
    </StackPanel>
</Window>
