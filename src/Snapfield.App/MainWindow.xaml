<Window x:Class="Snapfield.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Snapfield.App.ViewModels"
        mc:Ignorable="d"
        Title="Snapfield" Height="680" Width="780" MinHeight="560" MinWidth="680" Background="#0A0A11">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>

        <!-- calibration canvas palette (Aurora) -->
        <SolidColorBrush x:Key="bezelLocal"  Color="#141522"/>
        <SolidColorBrush x:Key="bezelRemote" Color="#141522"/>
        <SolidColorBrush x:Key="glowLocal"   Color="#5B87EE"/>
        <SolidColorBrush x:Key="glowRemote"  Color="#EBA956"/>
        <SolidColorBrush x:Key="deckLocal"   Color="#2E3A5C"/>
        <SolidColorBrush x:Key="deckRemote"  Color="#5A3F24"/>
        <SolidColorBrush x:Key="standWarm"   Color="#2A2F40"/>
        <SolidColorBrush x:Key="selection"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="cream"       Color="#EAECF6"/>
        <SolidColorBrush x:Key="creamDim"    Color="#B7BBCE"/>
        <SolidColorBrush x:Key="creamFaint"  Color="#828699"/>
        <LinearGradientBrush x:Key="screen" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#171826" Offset="0"/><GradientStop Color="#0D0E17" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="deskWood" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#14141F" Offset="0"/><GradientStop Color="#0A0A11" Offset="1"/>
        </LinearGradientBrush>

        <!-- top tab buttons (segmented) -->
        <Style x:Key="TabConnect" TargetType="Button" BasedOn="{StaticResource SegmentButton}">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Tag"><Setter.Value><CornerRadius>8,0,0,8</CornerRadius></Setter.Value></Setter>
            <Style.Triggers><DataTrigger Binding="{Binding IsConnect}" Value="True">
                <Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
        </Style>
        <Style x:Key="TabCalibrate" TargetType="Button" BasedOn="{StaticResource SegmentButton}">
            <Setter Property="Padding" Value="18,9"/>
            <Style.Triggers><DataTrigger Binding="{Binding IsCalibrate}" Value="True">
                <Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
        </Style>
        <Style x:Key="TabSettings" TargetType="Button" BasedOn="{StaticResource SegmentButton}">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Tag"><Setter.Value><CornerRadius>0,8,8,0</CornerRadius></Setter.Value></Setter>
            <Style.Triggers><DataTrigger Binding="{Binding IsSettings}" Value="True">
                <Setter Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
        </Style>

        <!-- role select: full-bleed halves (Connect tab, choose page). The whole
             half is the button; hover brightens its gradient toward the role color. -->
        <LinearGradientBrush x:Key="halfLeftIdle" StartPoint="0,0" EndPoint="0.7,1">
            <GradientStop Color="#101527" Offset="0"/><GradientStop Color="#0A0A11" Offset="0.75"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="halfLeftHover" StartPoint="0,0" EndPoint="0.7,1">
            <GradientStop Color="#16204A" Offset="0"/><GradientStop Color="#0C0E18" Offset="0.75"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="halfRightIdle" StartPoint="1,0" EndPoint="0.3,1">
            <GradientStop Color="#1D1610" Offset="0"/><GradientStop Color="#0A0A11" Offset="0.75"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="halfRightHover" StartPoint="1,0" EndPoint="0.3,1">
            <GradientStop Color="#2C2013" Offset="0"/><GradientStop Color="#0E0C0A" Offset="0.75"/>
        </LinearGradientBrush>
        <Style x:Key="HalfButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="KeyCap" TargetType="Border">
            <Setter Property="Background" Value="#1E2030"/>
            <Setter Property="BorderBrush" Value="#333650"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,1"/>
        </Style>

        <!-- calibration inspector -->
        <Style x:Key="InspectorButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,7,0,0"/>
        </Style>
        <Style x:Key="InspectorChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="7,1.5"/>
            <Setter Property="Background" Value="#1B1C26"/>
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style x:Key="InspectorKv" TargetType="Border">
            <Setter Property="BorderBrush" Value="#1E1F2C"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,5"/>
        </Style>

        <Style x:Key="RecentRow" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header + tabs + global status pill ═══ -->
        <Border Grid.Row="0" Background="#13131C" Padding="14,10">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="Snapfield" Foreground="{StaticResource cream}" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,18,0"/>

                <!-- connection state, visible on every tab; hover reveals 끊기 -->
                <Border DockPanel.Dock="Right" x:Name="StatusPill" VerticalAlignment="Center">
                    <Border.Style><Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="14"/>
                        <Setter Property="Padding" Value="11,5"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Background" Value="#1B1C26"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Hairline}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Network.PillKind}" Value="Ok">
                                <Setter Property="Background" Value="#12201A"/><Setter Property="BorderBrush" Value="#274434"/></DataTrigger>
                            <DataTrigger Binding="{Binding Network.PillKind}" Value="Live">
                                <Setter Property="Background" Value="#221A0F"/><Setter Property="BorderBrush" Value="#4A3A20"/></DataTrigger>
                        </Style.Triggers>
                    </Style></Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center">
                            <Ellipse.Style><Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#3A3D50"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Network.PillKind}" Value="Ok"><Setter Property="Fill" Value="#5FCF8A"/></DataTrigger>
                                    <DataTrigger Binding="{Binding Network.PillKind}" Value="Live"><Setter Property="Fill" Value="#EBA956"/></DataTrigger>
                                </Style.Triggers>
                            </Style></Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding Network.PillText}" FontSize="11.5" VerticalAlignment="Center" Margin="7,0,0,0">
                            <TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#9A9EAD"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Network.PillKind}" Value="Ok"><Setter Property="Foreground" Value="#B9E8CB"/></DataTrigger>
                                    <DataTrigger Binding="{Binding Network.PillKind}" Value="Live"><Setter Property="Foreground" Value="#F2D5A5"/></DataTrigger>
                                </Style.Triggers>
                            </Style></TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding Network.StopCommand}" Cursor="Hand" Margin="9,0,0,0">
                            <Button.Style><Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Template"><Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderBrush="{StaticResource Hairline}" BorderThickness="1,0,0,0" Padding="8,0,0,0">
                                            <TextBlock Text="끊기" FontSize="11" Foreground="#B7BBCE" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value></Setter>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsMouseOver, ElementName=StatusPill}" Value="True"/>
                                            <Condition Binding="{Binding Network.IsActive}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style></Button.Style>
                        </Button>
                    </StackPanel>
                </Border>

                <Border HorizontalAlignment="Left" Background="#1B1C26" BorderBrush="{StaticResource Hairline}" BorderThickness="1" CornerRadius="9">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="연결" Command="{Binding SelectConnectCommand}" Style="{StaticResource TabConnect}"/>
                        <Button Content="모니터 배치" Command="{Binding SelectCalibrateCommand}" Style="{StaticResource TabCalibrate}"/>
                        <Button Content="설정" Command="{Binding SelectSettingsCommand}" Style="{StaticResource TabSettings}"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">

            <!-- ═══════════ TAB · 연결 (network) ═══════════ -->
            <Grid DataContext="{Binding Network}"
                  Visibility="{Binding DataContext.IsConnect, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource B2V}}">

                <!-- role select: full-bleed left/right split — one click picks the role;
                     receiver starts waiting immediately (no 다음 / 대기 시작 steps) -->
                <Grid Visibility="{Binding IsChoosePage, Converter={StaticResource B2V}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource HalfButton}" Command="{Binding ChooseControllerCommand}"
                            Background="{StaticResource halfLeftIdle}" Tag="{StaticResource halfLeftHover}">
                        <StackPanel MaxWidth="230">
                            <Grid HorizontalAlignment="Center">
                                <StackPanel>
                                    <Border Width="64" Height="42" CornerRadius="6" BorderThickness="2" BorderBrush="#5B87EE">
                                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#171E33" Offset="0"/><GradientStop Color="#0D1120" Offset="1"/>
                                        </LinearGradientBrush></Border.Background>
                                        <Border.Effect><DropShadowEffect Color="#5B87EE" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/></Border.Effect>
                                    </Border>
                                    <Rectangle Width="9" Height="7" Fill="#2A2F40"/>
                                    <Rectangle Width="26" Height="4" RadiusX="2" RadiusY="2" Fill="#2A2F40"/>
                                </StackPanel>
                                <TextBlock Text="🖱️" FontSize="15" Margin="46,14,0,0"/>
                            </Grid>
                            <TextBlock Text="조작 기기" Foreground="{StaticResource cream}" FontSize="17" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,16,0,5"/>
                            <TextBlock Text="이 PC의 마우스·키보드로 다른 PC들을 조작" Foreground="#9A9EAD" FontSize="12"
                                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="200"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                <Border Style="{StaticResource KeyCap}">
                                    <TextBlock Text="←" FontFamily="Consolas" FontSize="11" Foreground="#9A9EAD"/>
                                </Border>
                                <TextBlock Text="또는 클릭" FontSize="11" Foreground="#5B6070" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="1" Style="{StaticResource HalfButton}" Command="{Binding ChooseReceiverCommand}"
                            Background="{StaticResource halfRightIdle}" Tag="{StaticResource halfRightHover}">
                        <StackPanel MaxWidth="230">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="64" Height="42" CornerRadius="6" BorderThickness="2" BorderBrush="#EBA956">
                                    <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2A2114" Offset="0"/><GradientStop Color="#171008" Offset="1"/>
                                    </LinearGradientBrush></Border.Background>
                                    <Border.Effect><DropShadowEffect Color="#EBA956" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/></Border.Effect>
                                </Border>
                                <Rectangle Width="9" Height="7" Fill="#2A2F40"/>
                                <Rectangle Width="26" Height="4" RadiusX="2" RadiusY="2" Fill="#2A2F40"/>
                            </StackPanel>
                            <TextBlock Text="수신 기기" Foreground="{StaticResource cream}" FontSize="17" FontWeight="Bold"
                                       HorizontalAlignment="Center" Margin="0,16,0,5"/>
                            <TextBlock Text="다른 PC의 조작을 받기 — 선택 즉시 대기 시작" Foreground="#9A9EAD" FontSize="12"
                                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="200"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                <Border Style="{StaticResource KeyCap}">
                                    <TextBlock Text="→" FontFamily="Consolas" FontSize="11" Foreground="#9A9EAD"/>
                                </Border>
                                <TextBlock Text="또는 클릭" FontSize="11" Foreground="#5B6070" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <!-- center divider with 또는 pill (decoration only) -->
                    <Grid Grid.ColumnSpan="2" IsHitTestVisible="False">
                        <Rectangle Width="1" Fill="{StaticResource Hairline}" HorizontalAlignment="Center"/>
                        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="#0A0A11"
                                BorderBrush="{StaticResource Hairline}" BorderThickness="1" CornerRadius="13" Padding="11,3">
                            <TextBlock Text="또는" FontSize="11" Foreground="#5B6070"/>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Margin="18">
                    <!-- controller: header + session block stay fixed on top;
                         discovery/recents/add scroll below (they can grow) -->
                    <DockPanel Visibility="{Binding IsControllerPage, Converter={StaticResource B2V}}">
                        <StackPanel DockPanel.Dock="Top">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="← 뒤로" Command="{Binding BackCommand}" Padding="10,5"/>
                            <TextBlock Text="조작 기기" Foreground="#EAECF6" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>

                        <!-- connected receivers (the hub can hold several at once) -->
                        <StackPanel Visibility="{Binding HasPeers, Converter={StaticResource B2V}}" Margin="0,12,0,0">
                            <!-- one-line cursor strip — the header pill carries the rest -->
                            <Border CornerRadius="8" Padding="11,6" BorderThickness="1">
                                <Border.Style><Style TargetType="Border">
                                    <Setter Property="Background" Value="#131A30"/>
                                    <Setter Property="BorderBrush" Value="#2A3A66"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PillKind}" Value="Live">
                                            <Setter Property="Background" Value="#221A0F"/>
                                            <Setter Property="BorderBrush" Value="#4A3A20"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style></Border.Style>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Detail}" FontSize="10.5" VerticalAlignment="Center">
                                        <TextBlock.Style><Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#8FA8E0"/>
                                            <Style.Triggers><DataTrigger Binding="{Binding PillKind}" Value="Live">
                                                <Setter Property="Foreground" Value="#E0BE8F"/></DataTrigger></Style.Triggers>
                                        </Style></TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Side}" Foreground="{StaticResource cream}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <TextBlock Text="연결된 기기" Foreground="#9A9EAD" FontSize="11.5" Margin="0,12,0,6"/>
                            <ItemsControl ItemsSource="{Binding ConnectedPeerViews}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- quiet row; hovering reveals rename + single-disconnect -->
                                        <Border Background="#161620" CornerRadius="8" Padding="11,7" Margin="0,0,0,5" MinHeight="36">
                                            <DockPanel LastChildFill="False">
                                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="#EAECF6" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Machine}" Foreground="#5B6070" FontSize="10.5" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                                        <StackPanel.Style><Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style></StackPanel.Style>
                                                        <Button Content="✎" Click="RenamePeer_Click" ToolTip="별명 지정"
                                                                Padding="6,2" FontSize="10.5" Cursor="Hand"/>
                                                        <Button Content="✕" Click="DisconnectPeer_Click" ToolTip="이 기기만 끊기"
                                                                Padding="6,2" FontSize="10.5" Margin="4,0,0,0" Cursor="Hand" Foreground="#E06A6A"/>
                                                    </StackPanel>
                                                    <TextBlock Text="● 연결됨" Foreground="#5FCF8A" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="커서를 화면 끝으로 밀어 넘어가세요 · Ctrl+Alt+←→ = 기기 전환 · 원격 조작 중 Ctrl 3번 = 즉시 복귀"
                                       Foreground="#5B6070" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            <Button Content="모두 끊기" Command="{Binding StopCommand}" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                        </StackPanel>
                        </StackPanel>

                        <!-- add receivers — always available; the hub can add more.
                             This part grows with history/discovery, so it scrolls. -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,6,0">
                            <!-- scanning hint until a receiver's beacon arrives -->
                            <TextBlock Foreground="#5B6070" FontSize="11.5" Margin="0,16,0,0" TextWrapping="Wrap"
                                       Text="같은 네트워크의 수신 기기를 찾는 중…  (상대 PC에서 Snapfield를 켜고 '수신 기기'를 선택하면 나타납니다)"
                                       Visibility="{Binding Scanning, Converter={StaticResource B2V}}"/>

                            <!-- ONE add-device list: discovery and history merged by host,
                                 online rows first; connected machines are hidden -->
                            <TextBlock Text="기기 추가" Foreground="#9A9EAD" FontSize="11.5" Margin="0,16,0,7"
                                       Visibility="{Binding HasAddDevices, Converter={StaticResource B2V}}"/>
                            <ItemsControl ItemsSource="{Binding AddDevices}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.AddDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RecentRow}">
                                                <Style.Triggers><DataTrigger Binding="{Binding Online}" Value="False">
                                                    <Setter Property="Opacity" Value="0.72"/></DataTrigger></Style.Triggers>
                                            </Style></Button.Style>
                                            <DockPanel LastChildFill="False">
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock Text="{Binding Name}" Foreground="#EAECF6" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="{Binding HostPort}" Foreground="#7E8296" FontSize="11" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style><Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="오프라인"/>
                                                            <Setter Property="Foreground" Value="#5B6070"/>
                                                            <Style.Triggers><DataTrigger Binding="{Binding Online}" Value="True">
                                                                <Setter Property="Text" Value="● 온라인"/>
                                                                <Setter Property="Foreground" Value="#5FCF8A"/></DataTrigger></Style.Triggers>
                                                        </Style></TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ActionText}" Foreground="#5B87EE" FontWeight="SemiBold" FontSize="12.5"
                                                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="아직 추가할 기기가 없어요. 상대 PC에서 수신 기기를 켜거나, IP로 직접 연결하세요." Foreground="#7E8296" FontSize="12"
                                       Margin="0,18,0,14" TextAlignment="Center" TextWrapping="Wrap" Visibility="{Binding NoAddDevices, Converter={StaticResource B2V}}"/>
                            <Button Content="＋ 새 기기 연결" Command="{Binding ShowNewFormCommand}" Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding Status}" Foreground="#7E8296" TextWrapping="Wrap" FontSize="11" Margin="0,12,0,0"/>
                        </StackPanel>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- receiver -->
                    <StackPanel Visibility="{Binding IsReceiverPage, Converter={StaticResource B2V}}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="← 뒤로" Command="{Binding BackCommand}" Padding="10,5"/>
                            <TextBlock Text="수신 기기" Foreground="#EAECF6" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsIdle, Converter={StaticResource B2V}}" Margin="0,16,0,0">
                            <Border Background="#161620" CornerRadius="12" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="이 PC의 IP (조작 기기에서 입력)" Foreground="#9A9EAD" FontSize="11.5"/>
                                    <TextBlock Text="{Binding LocalIps, Mode=OneWay}" Foreground="#EBB257" FontSize="20" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="연결 코드" Foreground="#9A9EAD" FontSize="11.5" Margin="0,12,0,0"/>
                                    <TextBlock Text="{Binding ReceiverPin, Mode=OneWay}" Foreground="#5FCF8A" FontSize="30" FontWeight="Bold" FontFamily="Consolas" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Button Content="대기 시작" Command="{Binding ListenCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Width="130" Margin="0,14,0,0"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsWaiting, Converter={StaticResource B2V}}" Margin="0,20,0,0" HorizontalAlignment="Center">
                            <Grid Width="90" Height="90" HorizontalAlignment="Center">
                                <Ellipse Width="90" Height="90" Fill="#5FCF8A" Opacity="0.28">
                                    <Ellipse.RenderTransform><ScaleTransform x:Name="pulseT" CenterX="45" CenterY="45" ScaleX="0.6" ScaleY="0.6"/></Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                                            <BeginStoryboard><Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="pulseT" Storyboard.TargetProperty="ScaleX" From="0.55" To="1" Duration="0:0:1.4" AutoReverse="True"/>
                                                <DoubleAnimation Storyboard.TargetName="pulseT" Storyboard.TargetProperty="ScaleY" From="0.55" To="1" Duration="0:0:1.4" AutoReverse="True"/>
                                            </Storyboard></BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <Ellipse Width="14" Height="14" Fill="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="연결 대기 중…" Foreground="#EAECF6" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <TextBlock Text="{Binding LocalIps, Mode=OneWay}" Foreground="#EBB257" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ReceiverPin, Mode=OneWay}" Foreground="#5FCF8A" FontWeight="Bold" FontFamily="Consolas" FontSize="16" Margin="14,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="중지" Command="{Binding StopCommand}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        </StackPanel>
                        <StackPanel Visibility="{Binding IsBeingControlled, Converter={StaticResource B2V}}" Margin="0,20,0,0">
                            <Border CornerRadius="12" Padding="16" Background="{Binding SideBrush}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Side}" Foreground="White" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Detail}" Foreground="#EEE" FontSize="11.5" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Button Content="중지" Command="{Binding StopCommand}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Status}" Foreground="#7E8296" TextWrapping="Wrap" FontSize="11" Margin="0,14,0,0"/>
                    </StackPanel>

                    <!-- new-connection bottom sheet -->
                    <Grid Margin="-18" Panel.ZIndex="10" Visibility="{Binding ShowNewForm, Converter={StaticResource B2V}}">
                        <Button Command="{Binding CloseSheetCommand}" Background="#99000000" Cursor="Arrow" Focusable="False">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}"/></ControlTemplate></Button.Template>
                        </Button>
                        <Border VerticalAlignment="Bottom" Background="#181A26" BorderBrush="{StaticResource Hairline}"
                                BorderThickness="1,1,0,0" CornerRadius="18,18,0,0" Padding="20,14,20,20">
                            <StackPanel>
                                <Border Width="38" Height="4" CornerRadius="2" Background="#3A3D50" Margin="0,0,0,14"/>
                                <TextBlock Text="새 기기 연결" Foreground="#EAECF6" FontSize="15" FontWeight="Bold" Margin="0,0,0,14"/>
                                <TextBlock Text="상대(수신) PC의 IP" Foreground="#9A9EAD" FontSize="11.5" Margin="0,0,0,5"/>
                                <TextBox x:Name="HostBox" Text="{Binding RemoteHost, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                                <!-- pin: six boxes, but ONE invisible TextBox drives them — the
                                     active-box highlight advances as you type (looks and feels
                                     like focus moving) without real focus juggling, so paste,
                                     backspace, and IME edge cases just work -->
                                <TextBlock Text="연결 코드" Foreground="#9A9EAD" FontSize="11.5" Margin="0,14,0,7"/>
                                <Grid HorizontalAlignment="Left" Cursor="IBeam">
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="PinB0" Width="42" Height="50" CornerRadius="9" Background="#10111A" BorderThickness="1.5" BorderBrush="#262838" Margin="0,0,8,0">
                                            <TextBlock x:Name="Pin0" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border x:Name="PinB1" Width="42" Height="50" CornerRadius="9" Background="#10111A" BorderThickness="1.5" BorderBrush="#262838" Margin="0,0,8,0">
                                            <TextBlock x:Name="Pin1" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border x:Name="PinB2" Width="42" Height="50" CornerRadius="9" Background="#10111A" BorderThickness="1.5" BorderBrush="#262838" Margin="0,0,8,0">
                                            <TextBlock x:Name="Pin2" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border x:Name="PinB3" Width="42" Height="50" CornerRadius="9" Background="#10111A" BorderThickness="1.5" BorderBrush="#262838" Margin="0,0,8,0">
                                            <TextBlock x:Name="Pin3" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border x:Name="PinB4" Width="42" Height="50" CornerRadius="9" Background="#10111A" BorderThickness="1.5" BorderBrush="#262838" Margin="0,0,8,0">
                                            <TextBlock x:Name="Pin4" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border x:Name="PinB5" Width="42" Height="50" CornerRadius="9" Background="#10111A" BorderThickness="1.5" BorderBrush="#262838">
                                            <TextBlock x:Name="Pin5" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBox x:Name="PinBox" Opacity="0" MaxLength="6"
                                             Text="{Binding ControllerPin, UpdateSourceTrigger=PropertyChanged}"
                                             InputMethod.IsInputMethodEnabled="False"
                                             TextChanged="PinBox_TextChanged"
                                             GotKeyboardFocus="PinBox_FocusChanged" LostKeyboardFocus="PinBox_FocusChanged"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,9,0,0"
                                            Visibility="{Binding PinError, Converter={StaticResource B2V}}">
                                    <TextBlock Text="✕" Foreground="#E06A6A" FontSize="12" Margin="0,0,6,0"/>
                                    <TextBlock Foreground="#E06A6A" FontSize="12" TextWrapping="Wrap" MaxWidth="380">
                                        <Run Text="{Binding PinErrorText, Mode=OneWay}"/><Run Text=" 수신 PC 화면의 초록 숫자를 다시 확인하세요."/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="수신 PC 화면의 초록 숫자 6자리 · 다 입력하면 자동으로 연결합니다"
                                           Foreground="#5B6070" FontSize="10.5" Margin="0,8,0,0"/>
                                <Button Content="고급 · 포트 설정 ▾" Command="{Binding ToggleAdvancedCommand}" HorizontalAlignment="Left"
                                        Margin="0,12,0,0" Padding="0,4" Background="Transparent" BorderThickness="0" Foreground="#7E8296" FontSize="11.5"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0" Visibility="{Binding ShowAdvanced, Converter={StaticResource B2V}}">
                                    <TextBlock Text="포트" Foreground="#9A9EAD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Text="{Binding Port}" Width="90"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                    <Button Content="취소" Command="{Binding CloseSheetCommand}" Margin="0,0,8,0"/>
                                    <Button Content="연결" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButton}" Width="110"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ═══════════ TAB · 모니터 배치 (calibration) ═══════════ -->
            <DockPanel x:Name="CalibrationRoot" DataContext="{Binding Calibration}"
                       Visibility="{Binding DataContext.IsCalibrate, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource B2V}}">
                <Border DockPanel.Dock="Bottom" Background="#13131C" Padding="12,7">
                    <DockPanel LastChildFill="False">
                        <Button DockPanel.Dock="Left" Content="자동 정렬로 초기화" Command="{Binding AutoArrangeCommand}"
                                Visibility="{Binding IsEditable, Converter={StaticResource B2V}}"/>
                        <Button DockPanel.Dock="Left" Content="프리셋 ▾" Click="PresetMenu_Click" Margin="7,0,0,0"
                                Visibility="{Binding IsEditable, Converter={StaticResource B2V}}"/>
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="11" Margin="12,0,0,0">
                            <TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers><DataTrigger Binding="{Binding SeamsVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                            </Style></TextBlock.Style>
                            <Run Text="‹·›" FontFamily="Consolas" FontWeight="Bold" Foreground="#5FCF8A"/><Run Text=" 커서 통과 구간" Foreground="#5B6070"/>
                            <Run Text="   ✕" Foreground="#E06A6A"/><Run Text=" 상대 화면 밖" Foreground="#5B6070"/>
                        </TextBlock>
                        <TextBlock DockPanel.Dock="Left" Text="휠 = 확대 · 드래그하면 통과 구간 표시" Foreground="#3F4354"
                                   FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers><DataTrigger Binding="{Binding SeamsVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers>
                            </Style></TextBlock.Style>
                        </TextBlock>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding ZoomText}" Foreground="#9A9EAD" FontSize="11"
                                   VerticalAlignment="Center" Margin="14,0,0,0"
                                   Visibility="{Binding IsZoomed, Converter={StaticResource B2V}}"/>
                        <Button DockPanel.Dock="Left" Content="화면에 맞추기" Command="{Binding ResetViewCommand}"
                                Margin="7,0,0,0" Padding="9,3" FontSize="11"
                                Visibility="{Binding IsZoomed, Converter={StaticResource B2V}}"/>
                        <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="11.5"
                                   Foreground="{StaticResource creamDim}"
                                   Text="🔒 조작 기기에서 관리하는 배치입니다 (읽기 전용)"
                                   Visibility="{Binding IsReadOnly, Converter={StaticResource B2V}}"/>
                        <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}" Foreground="{StaticResource creamDim}"
                                   VerticalAlignment="Center" FontSize="11.5"/>
                    </DockPanel>
                </Border>
                <!-- inspector: opens on selection, surfaces the right-click-only actions -->
                <Border DockPanel.Dock="Right" Width="212" Background="#161620"
                        BorderBrush="{StaticResource Hairline}" BorderThickness="1,0,0,0"
                        Visibility="{Binding HasSelection, Converter={StaticResource B2V}}">
                    <StackPanel Margin="14,12" DataContext="{Binding SelectedMonitor}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕" Padding="7,3" FontSize="10" VerticalAlignment="Top"
                                    Command="{Binding DataContext.ClearSelectionCommand, ElementName=CalibrationRoot}"/>
                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource cream}" FontSize="13.5"
                                       FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,11">
                            <Border Style="{StaticResource InspectorChip}">
                                <Border.Resources><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#9DB4E8"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsRemote}" Value="True">
                                        <Setter Property="Foreground" Value="#F2D5A5"/></DataTrigger></Style.Triggers>
                                </Style></Border.Resources>
                                <TextBlock Text="{Binding MachineLabel}" FontSize="9.5"/>
                            </Border>
                            <Border Style="{StaticResource InspectorChip}">
                                <TextBlock FontSize="9.5" Foreground="#9A9EAD">
                                    <TextBlock.Style><Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="로컬"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding IsRemote}" Value="True">
                                            <Setter Property="Text" Value="원격"/></DataTrigger></Style.Triggers>
                                    </Style></TextBlock.Style>
                                </TextBlock>
                            </Border>
                            <Border Style="{StaticResource InspectorChip}">
                                <TextBlock Text="{Binding KindLabel}" FontSize="9.5" Foreground="#9A9EAD"/>
                            </Border>
                        </StackPanel>
                        <Border Style="{StaticResource InspectorKv}">
                            <DockPanel>
                                <TextBlock Text="해상도" Foreground="#9A9EAD" FontSize="11.5"/>
                                <TextBlock Text="{Binding ResolutionText}" HorizontalAlignment="Right" Foreground="{StaticResource cream}" FontFamily="Consolas" FontSize="11.5"/>
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource InspectorKv}">
                            <DockPanel>
                                <TextBlock Text="실측 크기" Foreground="#9A9EAD" FontSize="11.5"/>
                                <TextBlock Text="{Binding PhysicalText}" HorizontalAlignment="Right" Foreground="{StaticResource cream}" FontFamily="Consolas" FontSize="11.5"/>
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource InspectorKv}">
                            <DockPanel>
                                <TextBlock Text="대각선" Foreground="#9A9EAD" FontSize="11.5"/>
                                <TextBlock Text="{Binding DiagonalText}" HorizontalAlignment="Right" Foreground="{StaticResource cream}" FontFamily="Consolas" FontSize="11.5"/>
                            </DockPanel>
                        </Border>
                        <Button Content="📐 실제 크기 보정 (인치)…" Style="{StaticResource InspectorButton}" Margin="0,13,0,0"
                                Click="ResizeMonitor_Click"
                                IsEnabled="{Binding DataContext.IsEditable, ElementName=CalibrationRoot}"/>
                        <Button Content="💻 기기 종류 전환" Style="{StaticResource InspectorButton}"
                                Click="ToggleKind_Click" ToolTip="모니터 → 노트북 → 스마트폰 → 태블릿 순환"
                                IsEnabled="{Binding DataContext.IsEditable, ElementName=CalibrationRoot}"/>
                        <Button Content="🗑 평면에서 제거" Click="RemoveMonitor_Click" ToolTipService.ShowOnDisabled="True">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource InspectorButton}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="ToolTip" Value="로컬 모니터는 제거할 수 없어요 (실제 연결된 화면)"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsRemote}" Value="True"/>
                                            <Condition Binding="{Binding DataContext.IsEditable, ElementName=CalibrationRoot}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="True"/>
                                        <Setter Property="ToolTip" Value="{x:Null}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style></Button.Style>
                        </Button>
                        <TextBlock Text="화면 크기가 실물과 다르면 경계에서 커서가 걸릴 수 있어요. 모니터의 대각선 인치를 알면 '실제 크기 보정'으로 맞추세요."
                                   Foreground="#5B6070" FontSize="10" TextWrapping="Wrap" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
                <Grid ClipToBounds="True" MouseWheel="Canvas_MouseWheel">
                <ItemsControl x:Name="Surface" ItemsSource="{Binding Monitors}" SizeChanged="Surface_SizeChanged" ClipToBounds="True"
                              MouseLeftButtonDown="Surface_MouseLeftButtonDown" MouseMove="Surface_MouseMove"
                              MouseLeftButtonUp="Surface_MouseLeftButtonUp">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas Background="{StaticResource deskWood}"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                            <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                            <Setter Property="Panel.ZIndex" Value="{Binding ZOrder}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                            <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" Cursor="SizeAll"
                                  ToolTip="{Binding Summary}"
                                  MouseLeftButtonDown="Monitor_MouseLeftButtonDown" MouseMove="Monitor_MouseMove" MouseLeftButtonUp="Monitor_MouseLeftButtonUp">
                                <Grid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="기기 종류 전환 (모니터·노트북·폰·태블릿)" Click="ToggleKind_Click"/>
                                        <MenuItem Header="실제 크기 보정 (인치)…" Click="ResizeMonitor_Click"/>
                                        <MenuItem Header="평면에서 제거 (원격 모니터만)" Click="RemoveMonitor_Click"/>
                                    </ContextMenu>
                                </Grid.ContextMenu>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-16" Panel.ZIndex="0">
                                    <StackPanel.Style><Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding IsMonitor}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                    </Style></StackPanel.Style>
                                    <Rectangle Width="9" Height="10" Fill="{StaticResource standWarm}"/>
                                    <Rectangle Width="48" Height="6" RadiusX="3" RadiusY="3" Fill="{StaticResource standWarm}"/>
                                </StackPanel>
                                <Border VerticalAlignment="Bottom" Height="11" Margin="-8,0,-8,-11" CornerRadius="0,0,7,7" Panel.ZIndex="0">
                                    <Border.Style><Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource deckLocal}"/>
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLaptop}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                            <DataTrigger Binding="{Binding IsRemote}" Value="True"><Setter Property="Background" Value="{StaticResource deckRemote}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style></Border.Style>
                                    <Rectangle Width="28" Height="3" RadiusX="1.5" RadiusY="1.5" Fill="#33000000" VerticalAlignment="Center"/>
                                </Border>
                                <Border CornerRadius="8" Padding="4" BorderThickness="1.6">
                                    <Border.Style><Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource bezelLocal}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource glowLocal}"/>
                                        <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#5B87EE" BlurRadius="26" ShadowDepth="0" Opacity="0.6"/></Setter.Value></Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource glowRemote}"/>
                                                <Setter Property="Effect"><Setter.Value><DropShadowEffect Color="#EBA956" BlurRadius="26" ShadowDepth="0" Opacity="0.6"/></Setter.Value></Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter Property="BorderBrush" Value="{StaticResource selection}"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style></Border.Style>
                                    <Grid>
                                        <Border CornerRadius="4" Background="{StaticResource screen}">
                                            <!-- size-adaptive: small cards show just the name (big and
                                                 readable); detail returns as the card/zoom grows. Full
                                                 spec is always in the tooltip and the inspector. -->
                                            <Viewbox Margin="8,7" MaxHeight="104">
                                                <StackPanel MaxWidth="170">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,1"
                                                                Visibility="{Binding ShowMeta, Converter={StaticResource B2V}}">
                                                        <TextBlock Text="{Binding MachineLabel}" Foreground="#9DB4E8" FontSize="8.5"/>
                                                        <TextBlock Text=" · " Foreground="#565A6E" FontSize="8.5"/>
                                                        <TextBlock Text="{Binding KindLabel}" Foreground="#8A8FA4" FontSize="8.5"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource cream}" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding ResolutionText}" Foreground="{StaticResource creamDim}" HorizontalAlignment="Center"
                                                               Visibility="{Binding ShowResolution, Converter={StaticResource B2V}}"/>
                                                    <TextBlock Text="{Binding PhysicalText}" Foreground="{StaticResource creamFaint}" HorizontalAlignment="Center"
                                                               Visibility="{Binding ShowMeta, Converter={StaticResource B2V}}"/>
                                                    <TextBlock Text="{Binding DiagonalText}" Foreground="#6E7286" HorizontalAlignment="Center"
                                                               Visibility="{Binding ShowMeta, Converter={StaticResource B2V}}"/>
                                                </StackPanel>
                                            </Viewbox>
                                        </Border>
                                        <!-- handheld (phone/tablet): punch-hole camera instead of stand/deck -->
                                        <Ellipse Width="5" Height="5" Fill="#4A4F66" HorizontalAlignment="Center"
                                                 VerticalAlignment="Top" Margin="0,5,0,0"
                                                 Visibility="{Binding IsHandheld, Converter={StaticResource B2V}}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- seam flow overlay: where the cursor crosses between machines.
                     Draw-only (no hit testing), and QUIET: only while dragging. -->
                <ItemsControl ItemsSource="{Binding ArrowMarkers}" IsHitTestVisible="False"
                              Visibility="{Binding SeamsVisible, Converter={StaticResource B2V}}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="‹·›" FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                       Foreground="#5FCF8A" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.Effect><DropShadowEffect Color="#5FCF8A" BlurRadius="9" ShadowDepth="0" Opacity="0.85"/></TextBlock.Effect>
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform x:Name="drift"/>
                                        <RotateTransform Angle="{Binding Angle}"/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="TextBlock.Loaded">
                                        <BeginStoryboard><Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="drift" Storyboard.TargetProperty="X"
                                                             From="-4" To="5" Duration="0:0:0.8"/>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.35" To="1" Duration="0:0:0.8"/>
                                        </Storyboard></BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <ItemsControl ItemsSource="{Binding BlockMarkers}" IsHitTestVisible="False"
                              Visibility="{Binding SeamsVisible, Converter={StaticResource B2V}}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="✕" FontSize="11" FontWeight="Bold" Foreground="#E06A6A" Opacity="0.85"
                                       Width="20" TextAlignment="Center">
                                <TextBlock.Effect><DropShadowEffect Color="#E06A6A" BlurRadius="7" ShadowDepth="0" Opacity="0.55"/></TextBlock.Effect>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </Grid>
            </DockPanel>

            <!-- ═══════════ TAB · 설정 (settings) ═══════════ -->
            <ScrollViewer DataContext="{Binding Settings}" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding DataContext.IsSettings, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource B2V}}">
                <StackPanel Margin="24,20" MaxWidth="460" HorizontalAlignment="Left">
                    <TextBlock Text="시작" Foreground="#9A9EAD" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <CheckBox Content="로그인 시 자동 실행" IsChecked="{Binding AutoStart}" Foreground="{StaticResource cream}" Margin="0,0,0,10"/>
                    <CheckBox Content="실행 시 마지막 연결 자동 복원" IsChecked="{Binding RestoreOnLaunch}" Foreground="{StaticResource cream}"/>

                    <TextBlock Text="입력" Foreground="#9A9EAD" FontSize="11" FontWeight="SemiBold" Margin="0,22,0,8"/>
                    <TextBlock Text="상대 PC에서의 커서 속도" Foreground="{StaticResource creamDim}" FontSize="12.5" Margin="0,0,0,4"/>
                    <Slider Minimum="0.25" Maximum="3.0" Value="{Binding Sensitivity}" TickFrequency="0.25" IsSnapToTickEnabled="True" Width="260" HorizontalAlignment="Left"/>

                    <TextBlock Text="이 PC 정보" Foreground="#9A9EAD" FontSize="11" FontWeight="SemiBold" Margin="0,22,0,8"/>
                    <Border Background="#161620" CornerRadius="10" Padding="14" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Foreground="#9A9EAD" FontSize="11.5">
                                <Run Text="기기 이름: "/><Run Text="{Binding MachineName, Mode=OneWay}" Foreground="#EAECF6" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Text="연결 코드 (상대가 나를 조작할 때 입력)" Foreground="#9A9EAD" FontSize="11.5" Margin="0,10,0,2"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PinDisplay, Mode=OneWay}" Foreground="#5FCF8A" FontSize="24" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                                <Button Command="{Binding CopyPinCommand}" Content="복사" Padding="9,3" FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                <Button Command="{Binding TogglePinCommand}" Padding="9,3" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center">
                                    <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Content" Value="가리기"/>
                                        <Style.Triggers><DataTrigger Binding="{Binding PinHidden}" Value="True">
                                            <Setter Property="Content" Value="보이기"/></DataTrigger></Style.Triggers>
                                    </Style></Button.Style>
                                </Button>
                                <Button Command="{Binding RegeneratePinCommand}" Content="재발급…" Padding="9,3" FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Foreground="#5B6070" FontSize="10.5" Margin="0,7,0,0" TextWrapping="Wrap" MaxWidth="380"
                                       Text="코드가 노출됐다면 재발급하세요 — 새 코드는 다음 연결부터 적용되고, 이미 연결된 기기는 끊기지 않습니다."/>
                            <TextBlock Text="{Binding PinNote}" Foreground="#9DB4E8" FontSize="10.5" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="네트워크" Foreground="#9A9EAD" FontSize="11" FontWeight="SemiBold" Margin="0,22,0,8"/>
                    <Button Content="방화벽 규칙 등록" Command="{Binding RegisterFirewallCommand}" HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding FirewallStatus}" Foreground="#7E8296" FontSize="11" Margin="0,7,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══ Toast stack (bottom-right, on top of everything; click = dismiss) ═══ -->
        <ItemsControl Grid.RowSpan="2" ItemsSource="{Binding Toasts}" Panel.ZIndex="100"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,14,14">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ToastItem}">
                    <Border Width="276" Background="#191B27" BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                            CornerRadius="9" Margin="0,8,0,0" Cursor="Hand" MouseLeftButtonDown="Toast_Click">
                        <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="4" Opacity="0.5"/></Border.Effect>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="3" CornerRadius="8,0,0,8">
                                <Border.Style><Style TargetType="Border">
                                    <Setter Property="Background" Value="#5FCF8A"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="Warn"><Setter Property="Background" Value="#EBA956"/></DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Err"><Setter Property="Background" Value="#E06A6A"/></DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Tip"><Setter Property="Background" Value="#5B87EE"/></DataTrigger>
                                    </Style.Triggers>
                                </Style></Border.Style>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="11,8,12,9">
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource cream}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Message}" Foreground="#9A9EAD" FontSize="10.5" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
