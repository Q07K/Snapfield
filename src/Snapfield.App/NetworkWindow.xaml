<Window x:Class="Snapfield.App.NetworkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Snapfield.App.ViewModels"
        Title="Snapfield — Network" Height="470" Width="470"
        Background="#0A0A11" Topmost="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V"/>

        <!-- toggle segment: active side filled with accent -->
        <Style x:Key="SegLeft" TargetType="Button" BasedOn="{StaticResource SegmentButton}">
            <Setter Property="Tag"><Setter.Value><CornerRadius>8,0,0,8</CornerRadius></Setter.Value></Setter>
            <Setter Property="Padding" Value="20,9"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsControllerSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SegRight" TargetType="Button" BasedOn="{StaticResource SegmentButton}">
            <Setter Property="Tag"><Setter.Value><CornerRadius>0,8,8,0</CornerRadius></Setter.Value></Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsReceiverSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- recent-connection list row -->
        <Style x:Key="RecentRow" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">

        <!-- ═══════════ Page 1 · Role select (B3 toggle) ═══════════ -->
        <StackPanel Visibility="{Binding IsChoosePage, Converter={StaticResource B2V}}" VerticalAlignment="Center">
            <TextBlock Foreground="#EAECF6" FontSize="15" HorizontalAlignment="Center">
                <Run Text="이 PC ("/><Run Text="{Binding MachineName, Mode=OneWay}" FontWeight="Bold"/><Run Text=")의 역할"/>
            </TextBlock>

            <Border HorizontalAlignment="Center" Margin="0,18,0,16"
                    Background="#1B1C26" BorderBrush="{StaticResource Hairline}" BorderThickness="1" CornerRadius="9">
                <StackPanel Orientation="Horizontal">
                    <Button Content="조작 기기" Command="{Binding SelectControllerCommand}" Style="{StaticResource SegLeft}"/>
                    <Button Content="수신 기기" Command="{Binding SelectReceiverCommand}" Style="{StaticResource SegRight}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding RoleDesc}" Foreground="#9A9EAD" TextAlignment="Center"
                       TextWrapping="Wrap" MaxWidth="300" FontSize="13" Margin="0,0,0,22"/>

            <Button Content="다음" Command="{Binding ProceedCommand}" Style="{StaticResource PrimaryButton}"
                    Width="140" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ═══════════ Page 2 · Controller (C2 recent list) ═══════════ -->
        <StackPanel Visibility="{Binding IsControllerPage, Converter={StaticResource B2V}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="← 뒤로" Command="{Binding BackCommand}" Padding="10,5"/>
                <TextBlock Text="조작 기기" Foreground="#EAECF6" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- IDLE: recent machines + add-new (the sheet opens over this) -->
            <StackPanel Visibility="{Binding IsIdle, Converter={StaticResource B2V}}">
                <TextBlock Text="최근 연결" Foreground="#9A9EAD" FontSize="11.5" Margin="0,16,0,7"
                           Visibility="{Binding HasRecent, Converter={StaticResource B2V}}"/>
                <ItemsControl ItemsSource="{Binding RecentConnections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource RecentRow}"
                                    Command="{Binding DataContext.ConnectRecentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding Name}" Foreground="#EAECF6" FontWeight="SemiBold" FontSize="13"/>
                                        <TextBlock Foreground="#7E8296" FontSize="11" Margin="0,3,0,0">
                                            <Run Text="{Binding Host, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="연결 ›" Foreground="#5B87EE"
                                               FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="아직 연결한 기기가 없어요. 새 기기를 추가하세요."
                           Foreground="#7E8296" FontSize="12" Margin="0,18,0,14" TextAlignment="Center"
                           Visibility="{Binding NoRecent, Converter={StaticResource B2V}}"/>

                <Button Content="＋ 새 기기 연결" Command="{Binding ShowNewFormCommand}"
                        Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- ACTIVE: status only (list + sheet give way) -->
            <StackPanel Visibility="{Binding IsActive, Converter={StaticResource B2V}}" Margin="0,16,0,0">
                <Border CornerRadius="11" Padding="14" Background="{Binding SideBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding Side}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Detail}" Foreground="#EEE" FontSize="11.5" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="커서를 화면 오른쪽 끝으로 밀어 상대 PC로 넘어가세요."
                           Foreground="#7E8296" FontSize="11.5" TextAlignment="Center" Margin="0,12,0,0"/>
                <Button Content="연결 끊기" Command="{Binding StopCommand}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
            </StackPanel>

            <TextBlock Text="{Binding Status}" Foreground="#7E8296" TextWrapping="Wrap" FontSize="11" Margin="0,12,0,0"/>
        </StackPanel>

        <!-- ═══════════ Page 3 · Receiver (R3 waiting pulse) ═══════════ -->
        <StackPanel Visibility="{Binding IsReceiverPage, Converter={StaticResource B2V}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="← 뒤로" Command="{Binding BackCommand}" Padding="10,5"/>
                <TextBlock Text="수신 기기" Foreground="#EAECF6" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- idle: show the info the controller needs, then Listen -->
            <StackPanel Visibility="{Binding IsIdle, Converter={StaticResource B2V}}" Margin="0,16,0,0">
                <Border Background="#161620" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="이 PC의 IP (조작 기기에서 입력)" Foreground="#9A9EAD" FontSize="11.5"/>
                        <TextBlock Text="{Binding LocalIps, Mode=OneWay}" Foreground="#EBB257" FontSize="20" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="연결 코드" Foreground="#9A9EAD" FontSize="11.5" Margin="0,12,0,0"/>
                        <TextBlock Text="{Binding ReceiverPin, Mode=OneWay}" Foreground="#5FCF8A" FontSize="30" FontWeight="Bold"
                                   FontFamily="Consolas" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <TextBlock Text="포트" Foreground="#9A9EAD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding Port}" Width="70"/>
                    <Button Content="대기 시작" Command="{Binding ListenCommand}" Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Width="120"/>
                </StackPanel>
            </StackPanel>

            <!-- waiting: pulse -->
            <StackPanel Visibility="{Binding IsWaiting, Converter={StaticResource B2V}}" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Grid Width="90" Height="90" HorizontalAlignment="Center">
                    <Ellipse Width="90" Height="90" Fill="#5FCF8A" Opacity="0.28">
                        <Ellipse.RenderTransform><ScaleTransform x:Name="pulseT" CenterX="45" CenterY="45" ScaleX="0.6" ScaleY="0.6"/></Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="pulseT" Storyboard.TargetProperty="ScaleX" From="0.55" To="1" Duration="0:0:1.4" AutoReverse="True"/>
                                        <DoubleAnimation Storyboard.TargetName="pulseT" Storyboard.TargetProperty="ScaleY" From="0.55" To="1" Duration="0:0:1.4" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <Ellipse Width="14" Height="14" Fill="#5FCF8A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="연결 대기 중…" Foreground="#EAECF6" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                <TextBlock Text="조작 기기에서 아래 정보를 입력하세요" Foreground="#9A9EAD" FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock Text="{Binding LocalIps, Mode=OneWay}" Foreground="#EBB257" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ReceiverPin, Mode=OneWay}" Foreground="#5FCF8A" FontWeight="Bold" FontFamily="Consolas" FontSize="16" Margin="14,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Content="중지" Command="{Binding StopCommand}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>

            <!-- being controlled -->
            <StackPanel Visibility="{Binding IsBeingControlled, Converter={StaticResource B2V}}" Margin="0,20,0,0">
                <Border CornerRadius="12" Padding="16" Background="{Binding SideBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding Side}" Foreground="White" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Detail}" Foreground="#EEE" FontSize="11.5" HorizontalAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Button Content="중지" Command="{Binding StopCommand}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
            </StackPanel>

            <TextBlock Text="{Binding Status}" Foreground="#7E8296" TextWrapping="Wrap" FontSize="11" Margin="0,14,0,0"/>
        </StackPanel>

        <!-- ═══════════ Bottom sheet · new connection (C-2) ═══════════ -->
        <Grid Margin="-18" Panel.ZIndex="10" Visibility="{Binding ShowNewForm, Converter={StaticResource B2V}}">
            <!-- dim backdrop; click to dismiss -->
            <Button Command="{Binding CloseSheetCommand}" Background="#99000000" Cursor="Arrow" Focusable="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}"/></ControlTemplate>
                </Button.Template>
            </Button>

            <Border VerticalAlignment="Bottom" Background="#181A26" BorderBrush="{StaticResource Hairline}"
                    BorderThickness="1,1,0,0" CornerRadius="18,18,0,0" Padding="20,14,20,20">
                <StackPanel>
                    <Border Width="38" Height="4" CornerRadius="2" Background="#3A3D50" Margin="0,0,0,14"/>
                    <TextBlock Text="새 기기 연결" Foreground="#EAECF6" FontSize="15" FontWeight="Bold" Margin="0,0,0,14"/>

                    <TextBlock Text="상대(수신) PC의 IP" Foreground="#9A9EAD" FontSize="11.5" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding RemoteHost, UpdateSourceTrigger=PropertyChanged}" FontSize="14"/>

                    <TextBlock Text="연결 코드 (수신 PC 화면의 초록 숫자)" Foreground="#9A9EAD" FontSize="11.5" Margin="0,12,0,5"/>
                    <TextBox Text="{Binding ControllerPin, UpdateSourceTrigger=PropertyChanged}" Width="150" HorizontalAlignment="Left" FontSize="14"/>

                    <!-- advanced (port) — hidden by default -->
                    <Button Content="고급 · 포트 설정 ▾" Command="{Binding ToggleAdvancedCommand}"
                            HorizontalAlignment="Left" Margin="0,12,0,0" Padding="0,4"
                            Background="Transparent" BorderThickness="0" Foreground="#7E8296" FontSize="11.5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding ShowAdvanced, Converter={StaticResource B2V}}">
                        <TextBlock Text="포트" Foreground="#9A9EAD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding Port}" Width="90"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="취소" Command="{Binding CloseSheetCommand}" Margin="0,0,8,0"/>
                        <Button Content="연결" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryButton}" Width="110"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
