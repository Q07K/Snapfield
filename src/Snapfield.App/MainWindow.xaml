<Window x:Class="Snapfield.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snapfield.App"
        xmlns:vm="clr-namespace:Snapfield.App.ViewModels"
        mc:Ignorable="d"
        Title="Snapfield — Calibration" Height="640" Width="1000"
        Background="#0A0A11">
    <Window.DataContext>
        <vm:CalibrationViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Aurora palette: near-black ground, screens glow in their role color -->
        <SolidColorBrush x:Key="bezelLocal"  Color="#141522"/>
        <SolidColorBrush x:Key="bezelRemote" Color="#141522"/>
        <SolidColorBrush x:Key="glowLocal"   Color="#5B87EE"/>
        <SolidColorBrush x:Key="glowRemote"  Color="#EBA956"/>
        <SolidColorBrush x:Key="deckLocal"   Color="#2E3A5C"/>
        <SolidColorBrush x:Key="deckRemote"  Color="#5A3F24"/>
        <SolidColorBrush x:Key="standWarm"   Color="#2A2F40"/>
        <SolidColorBrush x:Key="selection"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="cream"       Color="#EAECF6"/>
        <SolidColorBrush x:Key="creamDim"    Color="#B7BBCE"/>
        <SolidColorBrush x:Key="creamFaint"  Color="#828699"/>
        <LinearGradientBrush x:Key="screen" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#171826" Offset="0"/>
            <GradientStop Color="#0D0E17" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="deskWood" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#14141F" Offset="0"/>
            <GradientStop Color="#0A0A11" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#13131C" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Snapfield" Foreground="{StaticResource cream}" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- Segmented control: fused buttons, hairline dividers, rounded ends -->
                <Border Background="#1B1C26" BorderBrush="{StaticResource Hairline}" BorderThickness="1"
                        CornerRadius="9" SnapsToDevicePixels="True">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Re-detect" Command="{Binding ReDetectCommand}" Style="{StaticResource SegmentButton}">
                            <Button.Tag><CornerRadius>8,0,0,8</CornerRadius></Button.Tag>
                        </Button>
                        <Button Content="Auto-arrange" Command="{Binding AutoArrangeCommand}" Style="{StaticResource SegmentButton}"/>
                        <Button Content="Save layout" Command="{Binding SaveCommand}" Style="{StaticResource SegmentButton}"/>
                        <Button Content="Input Engine…" Click="OpenEngine_Click" Style="{StaticResource SegmentButton}"/>
                        <Button Content="Network…" Click="OpenNetwork_Click" Style="{StaticResource SegmentButton}" BorderThickness="0">
                            <Button.Tag><CornerRadius>0,8,8,0</CornerRadius></Button.Tag>
                        </Button>
                    </StackPanel>
                </Border>

                <TextBlock Text="실제 책상 배치대로 끌어다 놓으세요. 가장자리는 자동으로 붙습니다."
                           Foreground="#6E7288" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#13131C" Padding="10,5">
            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource creamDim}"/>
        </Border>

        <!-- Calibration surface (the desk) -->
        <ItemsControl x:Name="Surface" ItemsSource="{Binding Monitors}"
                      SizeChanged="Surface_SizeChanged" ClipToBounds="True">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Background="{StaticResource deskWood}"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                    <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                    <!-- Lower-on-the-desk devices paint on top, so a tall monitor's
                         stand never sits over a laptop placed below it. -->
                    <Setter Property="Panel.ZIndex" Value="{Binding ZOrder}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                    <Grid Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" Cursor="SizeAll"
                          MouseLeftButtonDown="Monitor_MouseLeftButtonDown"
                          MouseMove="Monitor_MouseMove"
                          MouseLeftButtonUp="Monitor_MouseLeftButtonUp">
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="노트북 ↔ 모니터 전환" Click="ToggleKind_Click"/>
                                <MenuItem Header="실제 크기 보정 (인치)…" Click="ResizeMonitor_Click"/>
                                <MenuItem Header="평면에서 제거 (원격 모니터만)" Click="RemoveMonitor_Click"/>
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <!-- Monitor stand: neck + foot, sits just below the screen -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Margin="0,0,0,-16" Panel.ZIndex="0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLaptop}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Rectangle Width="9" Height="10" Fill="{StaticResource standWarm}"/>
                            <Rectangle Width="48" Height="6" RadiusX="3" RadiusY="3" Fill="{StaticResource standWarm}"/>
                        </StackPanel>

                        <!-- Laptop deck: a ledge slightly wider than the screen -->
                        <Border VerticalAlignment="Bottom" Height="11" Margin="-8,0,-8,-11"
                                CornerRadius="0,0,7,7" Panel.ZIndex="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource deckLocal}"/>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLaptop}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource deckRemote}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Rectangle Width="28" Height="3" RadiusX="1.5" RadiusY="1.5"
                                       Fill="#33000000" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Screen: warm bezel wrapping a dark panel -->
                        <Border CornerRadius="8" Padding="4" BorderThickness="1.6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource bezelLocal}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource glowLocal}"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#5B87EE" BlurRadius="26" ShadowDepth="0" Opacity="0.6"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource glowRemote}"/>
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#EBA956" BlurRadius="26" ShadowDepth="0" Opacity="0.6"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource selection}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Border CornerRadius="4" Background="{StaticResource screen}">
                                <Viewbox Margin="8,7" MaxHeight="104">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,1">
                                            <TextBlock Text="{Binding MachineId}" Foreground="#9DB4E8" FontSize="8.5"/>
                                            <TextBlock Text=" · " Foreground="#565A6E" FontSize="8.5"/>
                                            <TextBlock Text="{Binding KindLabel}" Foreground="#8A8FA4" FontSize="8.5"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource cream}"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ResolutionText}" Foreground="{StaticResource creamDim}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding PhysicalText}" Foreground="{StaticResource creamFaint}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding DiagonalText}" Foreground="#6E7286"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Viewbox>
                            </Border>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</Window>
