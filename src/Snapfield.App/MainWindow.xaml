<Window x:Class="Snapfield.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Snapfield.App"
        xmlns:vm="clr-namespace:Snapfield.App.ViewModels"
        mc:Ignorable="d"
        Title="Snapfield — Calibration" Height="640" Width="1000"
        Background="#1E1E22">
    <Window.DataContext>
        <vm:CalibrationViewModel/>
    </Window.DataContext>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#2A2A30" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Snapfield" Foreground="#EEE" FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="Re-detect" Command="{Binding ReDetectCommand}" Margin="0,0,8,0" Padding="12,4"/>
                <Button Content="Auto-arrange" Command="{Binding AutoArrangeCommand}" Margin="0,0,8,0" Padding="12,4"/>
                <Button Content="Save layout" Command="{Binding SaveCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Input Engine…" Click="OpenEngine_Click" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Network…" Click="OpenNetwork_Click" Padding="12,4"/>
                <TextBlock Text="Drag monitors to match their real physical arrangement. Edges snap."
                           Foreground="#999" VerticalAlignment="Center" Margin="20,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#2A2A30" Padding="10,5">
            <TextBlock Text="{Binding StatusText}" Foreground="#AAB"/>
        </Border>

        <!-- Calibration surface -->
        <ItemsControl x:Name="Surface" ItemsSource="{Binding Monitors}"
                      SizeChanged="Surface_SizeChanged" ClipToBounds="True">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Background="#17171A"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}"/>
                    <Setter Property="Canvas.Top" Value="{Binding CanvasTop}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                    <Border Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}"
                            CornerRadius="6" BorderThickness="2" Cursor="SizeAll"
                            MouseLeftButtonDown="Monitor_MouseLeftButtonDown"
                            MouseMove="Monitor_MouseMove"
                            MouseLeftButtonUp="Monitor_MouseLeftButtonUp">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="평면에서 제거 (원격 모니터만)" Click="RemoveMonitor_Click"/>
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2E5CB8"/>
                                <Setter Property="BorderBrush" Value="#4A7BE0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                        <Setter Property="Background" Value="#B8722E"/>
                                        <Setter Property="BorderBrush" Value="#E0A44A"/>
                                    </DataTrigger>
                                    <!-- Selection only brightens the border so the
                                         remote (orange) vs local (blue) fill stays readable. -->
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BorderBrush" Value="#FFFFFF"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Viewbox Margin="6" MaxHeight="90">
                            <StackPanel>
                                <TextBlock Text="{Binding MachineId}" Foreground="#FFE9B0" FontSize="9"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding ResolutionText}" Foreground="#DDE"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding PhysicalText}" Foreground="#BCD"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding DiagonalText}" Foreground="#9AB"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Viewbox>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </DockPanel>
</Window>
